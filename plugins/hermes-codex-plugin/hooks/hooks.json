{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \"$PLUGIN_ROOT/hooks/session_start.py\"",
            "timeout": 10,
            "statusMessage": "Loading Hermes Codex Plugin memory"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \"$PLUGIN_ROOT/hooks/user_prompt_submit.py\"",
            "timeout": 10,
            "statusMessage": "Searching local memory"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \"$PLUGIN_ROOT/hooks/stop.py\"",
            "timeout": 10,
            "statusMessage": "Capturing assistant reply"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \"$PLUGIN_ROOT/hooks/pre_compact.py\"",
            "timeout": 20,
            "statusMessage": "Capturing transcript snapshot"
          }
        ]
      }
    ]
  }
}
